{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "SharePoint List API"
  },
  "host": "testtraveflow.traveport-test.de",
  "basePath": "/",
  "schemes": ["https"],
  "consumes": ["application/json", "application/json;odata=verbose"],
  "produces": ["application/json", "application/json;odata=verbose"],
  "paths": {
    "/_api/web/lists/getbytitle('{listTitle}')/items": {
      "post": {
        "operationId": "CreateListItem",
        "parameters": [
          {
            "name": "listTitle",
            "in": "path",
            "required": true,
            "type": "string",
            "default": "TestMatthias"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/CreateItemRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Item created",
            "schema": {
              "type": "object",
              "$ref": "#/definitions/CreateItemResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "CreateItemRequest": {
      "type": "object",
      "required": ["__metadata", "Title"],
      "properties": {
        "__metadata": {
          "type": "string",
          "example": "SP.Data.TestMatthiasListItem"
        },
        "Title": {
          "type": "string",
          "example": "Created via API"
        }
      }
    },
    "Item": {
      "type": "object",
      "properties": {
        "Id": {
          "type": "integer"
        },
        "Title": {
          "type": "string"
        }
      }
    },
    "CreateItemResponse": {
      "type": "object",
      "properties": {
        "d": {
          "$ref": "#/definitions/Item"
        }
      }
    }
  }
}
