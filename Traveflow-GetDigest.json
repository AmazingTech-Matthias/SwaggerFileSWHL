{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "SharePoint Context API"
  },
  "host": "testtraveflow.traveport-test.de",
  "basePath": "",
  "schemes": ["https"],
  "consumes": [],
  "produces": ["application/json", "application/json;odata=verbose"],
  "paths": {
    "/raumgruppen/{siteCollection}/_api/contextinfo": {
      "post": {
        "operationId": "GetDigest",
        "summary": "Retrieve SharePoint request digest",
        "parameters": [
          {
            "name": "siteCollection",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Digest response",
            "schema": {
              "$ref": "#/definitions/ContextInfoResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "ContextInfoResponse": {
      "type": "object",
      "properties": {
        "value": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ResponseItems"
          }
        }
      }
    },
    "ResponseItems": {
      "type": "object",
      "description": "Retrieving properties",
      "properties": {
        "FormDigestValue": {
          "type": "string"
        },
        "FormDigestTimeoutSeconds": {
          "type": "integer"
        },
        "LibraryVersion": {
          "type": "string"
        },
        "SiteFullUrl": {
          "type": "string"
        },
        "WebFullUrl": {
          "type": "string"
        }
      }
    }
  }
}
