{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "SharePoint Context API"
  },
  "host": "testtraveflow.traveport-test.de",
  "basePath": "/",
  "schemes": ["https"],
  "consumes": [],
  "produces": ["application/json", "application/json;odata=verbose"],
  "paths": {
    "/_api/contextinfo": {
      "post": {
        "operationId": "GetDigest",
        "summary": "Retrieve SharePoint request digest",
        "responses": {
          "200": {
            "description": "Digest response",
            "schema": {
              "$ref": "#/definitions/ContextInfo"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "ContextInfo": {
      "type": "object",
      "properties": {
        "FormDigestValue": {
          "type": "string",
          "example": "0x16AE2C8DA4C4E87126F72AA2277D25F4EC49E..."
        },
        "FormDigestTimeoutSeconds": {
          "type": "integer",
          "example": 1800
        },
        "LibraryVersion": {
          "type": "string",
          "example": "16.0.10417.20102"
        },
        "SiteFullUrl": {
          "type": "string",
          "example": "https://testtraveflow.traveport-test.de/raumgruppen/Cockpit-1"
        },
        "WebFullUrl": {
          "type": "string",
          "example": "https://testtraveflow.traveport-test.de/raumgruppen/Cockpit-1"
        }
      }
    }
  }
}
