{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "SharePoint Context API"
  },
  "host": "testtraveflow.traveport-test.de",
  "basePath": "",
  "schemes": ["https"],
  "consumes": [],
  "produces": ["application/json", "application/json;odata=verbose"],
  "paths": {
    "/raumgruppen/{siteCollection}/_api/contextinfo": {
      "post": {
        "operationId": "GetDigest",
        "summary": "Retrieve SharePoint request digest",
        "parameters": [
          {
            "name": "siteCollection",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/FormDigestResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "FormDigestResponse": {
      "type": "object",
      "properties": {
        "FormDigestValue": {
          "type": "string",
          "example": "0x123ABCDEF..."
        },
        "FormDigestTimeoutSeconds": {
          "type": "integer",
          "example": 1800
        },
        "LibraryVersion": {
          "type": "string",
          "example": "16.0.10337.12109"
        },
        "SiteFullUrl": {
          "type": "string",
          "example": "https://testtraveflow.traveport-test.de/raumgruppen/site"
        },
        "WebFullUrl": {
          "type": "string"
        }
      }
    }
  }
}
